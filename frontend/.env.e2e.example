# Copy to .env.e2e and fill in. The e2e suite uses these to:
#   1. Apply the vendored seed (scripts/seed-data.sql) before running
#   2. Sign in via Clerk's hosted UI as the test user
#
# E2E_USER_EMAIL must be a Clerk dev account in the form +clerk_test@... so
# Clerk skips its captcha and accepts the static OTP 424242.

E2E_USER_EMAIL=test1+clerk_test@example.com
E2E_USER_PASSWORD=bred6BAILEY@craziest

# Clerk identity_user_id of the above account. Find it after first sign-in:
#   psql -d mmr_project -c "SELECT identity_user_id FROM users WHERE email = '<email>'"
E2E_IDENTITY_USER_ID=user_3AxNl1GZF7UG4Og7EzDoqwSVHo3

# Database connection used by the seed script
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mmr_project
DB_USER=postgres
DB_PASS=this_is_a_hard_password1337

# Override base URL if your dev server runs on a different port
# E2E_BASE_URL=http://localhost:5173
