{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite dev --host",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "generate-api": "openapi-generator-cli generate -i http://localhost:8081/swagger/v1/swagger.json -g typescript-fetch -o src/api --additional-properties=supportsES6=true --skip-validate-spec",
    "generate-api-v3": "openapi-generator-cli generate -i http://localhost:8081/swagger/v3/swagger.json -g typescript-fetch -o src/api-v3 --additional-properties=supportsES6=true --skip-validate-spec",
    "start": "node -r dotenv/config build",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.30.2",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/eslint": "^8.56.12",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-svelte": "^2.46.1",
    "postcss": "^8.5.8",
    "postcss-load-config": "^5.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.53.12",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^3.4.19",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "type": "module",
  "dependencies": {
    "@carbon/charts-svelte": "^1.27.3",
    "bits-ui": "^1.8.0",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "d3-cloud": "^1.2.9",
    "d3-sankey": "^0.12.3",
    "dotenv": "^16.6.1",
    "formsnap": "^2.0.1",
    "lucide-svelte": "^0.577.0",
    "svelte-clerk": "^0.20.6",
    "sveltekit-superforms": "^2.30.0",
    "tailwind-merge": "^2.6.1",
    "tailwind-variants": "^0.3.1",
    "zod": "^3.25.76"
  }
}
